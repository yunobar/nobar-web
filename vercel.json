{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://dev-album.up.railway.app/api/$1"
    },
    {
      "source": "/((?!api|static|favicon\\.ico|.*\\..*).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}